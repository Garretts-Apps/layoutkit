{
  "name": "layoutkit-css",
  "version": "0.1.0",
  "description": "The first layout language for the web — pure CSS. Style <lk-*> tags with attribute selectors. Zero dependencies, no JavaScript, no build step, no FOUC.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/garrett-s-apps/layoutkit.git",
    "directory": "packages/layoutkit"
  },
  "keywords": ["layout", "css", "flexbox", "grid", "design-system", "zero-dependency", "no-build", "custom-tags", "semantic-html", "html"],
  "exports": {
    ".": "./layoutkit.css",
    "./layoutkit.css": "./layoutkit.css"
  },
  "main": "./layoutkit.css",
  "style": "./layoutkit.css",
  "unpkg": "./layoutkit.css",
  "jsdelivr": "./layoutkit.css",
  "files": ["layoutkit.css", "gen.mjs", "README.md"],
  "sideEffects": ["*.css"],
  "scripts": {
    "build": "node gen.mjs"
  }
}
