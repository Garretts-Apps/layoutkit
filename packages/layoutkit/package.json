{
  "name": "layoutkit-css",
  "version": "1.2.0",
  "description": "A layout language for the web — pure CSS. Style <lk-*> tags with attribute selectors. Zero dependencies, no JavaScript, no build step, no FOUC.",
  "license": "MIT",
  "homepage": "https://layoutkit.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Garretts-Apps/layoutkit.git",
    "directory": "packages/layoutkit"
  },
  "bugs": {
    "url": "https://github.com/Garretts-Apps/layoutkit/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": ["layout", "css", "flexbox", "grid", "design-system", "design-tokens", "cascade-layers", "logical-properties", "zero-dependency", "no-build", "custom-tags", "semantic-html", "html"],
  "exports": {
    ".": "./layoutkit.css",
    "./layoutkit.css": "./layoutkit.css"
  },
  "main": "./layoutkit.css",
  "style": "./layoutkit.css",
  "unpkg": "./layoutkit.css",
  "jsdelivr": "./layoutkit.css",
  "files": ["layoutkit.css", "gen.mjs", "README.md", "CHANGELOG.md", "LICENSE"],
  "sideEffects": ["*.css"],
  "scripts": {
    "build": "node gen.mjs"
  }
}
