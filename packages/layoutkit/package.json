{
  "name": "layoutkit-css",
  "version": "1.3.2",
  "description": "A tiny pure-CSS layout vocabulary for readable app structure.",
  "license": "MIT",
  "homepage": "https://layoutkit.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Garretts-Apps/layoutkit.git",
    "directory": "packages/layoutkit"
  },
  "bugs": {
    "url": "https://github.com/Garretts-Apps/layoutkit/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "layout",
    "css",
    "flexbox",
    "grid",
    "layout-primitives",
    "cascade-layers",
    "logical-properties",
    "zero-dependency",
    "no-build",
    "custom-tags",
    "html"
  ],
  "types": "./jsx.d.ts",
  "exports": {
    ".": {
      "types": "./jsx.d.ts",
      "default": "./layoutkit.css"
    },
    "./layoutkit.css": "./layoutkit.css",
    "./jsx.d.ts": "./jsx.d.ts"
  },
  "main": "./layoutkit.css",
  "style": "./layoutkit.css",
  "unpkg": "./layoutkit.css",
  "jsdelivr": "./layoutkit.css",
  "files": [
    "layoutkit.css",
    "jsx.d.ts",
    "README.md",
    "CONTRIBUTING.md",
    "CHANGELOG.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "sideEffects": [
    "*.css"
  ]
}
